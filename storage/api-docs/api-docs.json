                                        "example": "08:30"
                                    },
                                    "arrival_time": {
                                        "type": "string",
                                        "example": "11:00"
                                    },
                                    "seat_class": {
                                        "type": "string",
                                        "enum": [
                                            "economy",
                                            "business"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Booking updated"
                    },
                    "403": {
                        "description": "Forbidden"
                    }
                },
                "security": [
                    {
                        "sanctum": []
