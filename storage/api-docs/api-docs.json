            "post": {
                "tags": [
                    "Payments"
                ],
                "summary": "Process payment for a booking",
                "operationId": "a09d2f1ffe23c1491d333e6026c5dafd",
                "parameters": [
                    {
                        "name": "booking",
                        "in": "path",
                        "required": true,
