                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Payment processed"
                    },
                    "422": {
                        "description": "Already paid or booking cancelled"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
