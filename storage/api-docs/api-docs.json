                                    },
                                    "customer_email": {
                                        "type": "string",
                                        "example": "ali@test.com"
                                    },
                                    "flight_number": {
                                        "type": "string",
                                        "example": "IR455"
                                    },
                                    "origin": {
                                        "type": "string",
