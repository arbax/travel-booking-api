        "/api/bookings/{booking}/passengers": {
            "get": {
                "tags": [
                    "Passengers"
                ],
                "summary": "List passengers for a booking",
                "operationId": "d1fc4d7ad145365da8c4927957c17273",
                "parameters": [
                    {
                        "name": "booking",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of passengers"
                    },
                    "403": {
                        "description": "Forbidden"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Passengers"
                ],
                "summary": "Add a passenger to a booking",
                "operationId": "17a7cb6e6c940ca538113fdc4b16bed2",
                "parameters": [
                    {
                        "name": "booking",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "first_name",
                                    "last_name",
                                    "birth_date"
                                ],
                                "properties": {
                                    "first_name": {
                                        "type": "string",
                                        "example": "Ali"
                                    },
                                    "last_name": {
                                        "type": "string",
                                        "example": "Rezaei"
                                    },
                                    "national_id": {
                                        "type": "string",
                                        "example": "1234567890",
                                        "nullable": true
                                    },
                                    "passport_number": {
                                        "type": "string",
                                        "example": "A12345678",
                                        "nullable": true
                                    },
                                    "birth_date": {
                                        "type": "string",
                                        "example": "1990-05-15"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Passenger added"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
